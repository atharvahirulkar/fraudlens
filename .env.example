# FraudLens environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM backend ─────────────────────────────────────────────────────────────
# "openai"  → GPT-4o-mini via OpenAI API  (production)
# "ollama"  → Mistral 7B via local Ollama  (local dev, no API key needed)
LLM_BACKEND=openai

# OpenAI API key — required when LLM_BACKEND=openai
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── MLflow ──────────────────────────────────────────────────────────────────
# Local dev (docker-compose): http://mlflow:5000
# Production (App Runner):    file:///app/mlruns  ← set by Dockerfile, leave as-is
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Qdrant vector store ─────────────────────────────────────────────────────
# Local dev (docker-compose): http://qdrant:6333
# AWS (no Qdrant deployed):   leave empty → retrieval silently disabled
QDRANT_URL=http://localhost:6333

# ── Ollama (only needed when LLM_BACKEND=ollama) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
